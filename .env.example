# Google Cloud サービスアカウント（JSON の client_email / private_key に相当）
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# 改行は \n のまま1行で入れるか、Vercel 等では実改行に展開される想定で .replace(/\\n/g, '\n') をコード側で実施済み
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# スプレッドシート ID（URL の /d/ と /edit の間）
GOOGLE_SHEET_ID=1popGFMaXaQP9h_uRF1UWd3ddvosE9_GP9QVxQ1driHU

# 一覧 GET のメモリキャッシュ（ミリ秒）。既定 20000。短時間の再読み込みで Sheets 429 を抑える。0 で無効
# SHIFTS_LIST_CACHE_TTL_MS=20000

# 開発・テスト用「全データ削除」API 用。未設定のときは全削除を 403 にする
# 管理画面のトークン入力欄に同じ値を入れて /api/shifts POST { action: "clearAllDataRows" } を実行
# SHIFT_ADMIN_CLEAR_TOKEN=ランダムな長い文字列
