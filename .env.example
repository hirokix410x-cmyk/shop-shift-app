# Google Cloud サービスアカウント（JSON の client_email / private_key に相当）
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# 改行は \n のまま1行で入れるか、Vercel 等では実改行に展開される想定で .replace(/\\n/g, '\n') をコード側で実施済み
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# スプレッドシート ID（URL の /d/ と /edit の間）
GOOGLE_SHEET_ID=1popGFMaXaQP9h_uRF1UWd3ddvosE9_GP9QVxQ1driHU
